# GitHub repository containing blog post Markdown files (owner/repo)
LEMMA_POSTS_REPO=owner/repo
# Branch to read from (default: main)
LEMMA_POSTS_BRANCH=main
# Subdirectory within the repo where .md files live (default: root)
LEMMA_POSTS_PATH=
# Personal access token — required for private repos, recommended for rate limits
LEMMA_GH_TOKEN=

# Google Analytics Measurement ID (e.g., G-XXXXXXXXXX)
PUBLIC_GOOGLE_ANALYTICS_ID=
