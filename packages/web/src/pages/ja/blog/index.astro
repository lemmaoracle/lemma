---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/Navigation.astro";
import BlogList from "../../../components/BlogList.astro";
import { getBlogSections } from "../../../data/blog";
import { getTranslations } from "../../../i18n/translations";

const locale = "ja";
const t = getTranslations(locale);
const base = "/ja";
const sections = await getBlogSections(locale);
---

<Layout locale={locale} title={`${t.blog.title} — Lemma Oracle`} description={t.blog.subtitle}>
  <div class="relative min-h-screen bg-[#FAFAF8]">
    <Navigation locale={locale} t={t.nav} base={base} />
    <main class="relative pt-14 pb-16">
      <div class="mx-auto max-w-[1400px] px-8 pt-16">
        <h1 class="mb-4 font-mono text-[11px] tracking-wider text-black/30 uppercase">
          {t.blog.title}
        </h1>
        <p class="mb-12 font-mono text-[13px] text-black/60">{t.blog.subtitle}</p>
      </div>
      <BlogList sections={sections} t={t.blog} base={base} />
    </main>
    <footer class="border-t border-black/5 py-8">
      <div class="mx-auto max-w-[1400px] px-8">
        <p class="font-mono text-[10px] tracking-wide text-black/30">
          {t.footer.copyright}
        </p>
      </div>
    </footer>
  </div>
</Layout>
