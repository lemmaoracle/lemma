---
import BlogIndexTemplate from "../../../templates/BlogIndexTemplate.astro";
import { getBlogSections } from "../../../data/blog";
import { getTranslations } from "../../../i18n/translations";

const locale = "ja";
const t = getTranslations(locale);
const base = "/ja";
const blogPath = "/ja/blog";
const sections = await getBlogSections(locale);
const filterSection = sections.find(
  (s) => s.section === "エッセイ" || s.section === "Essays"
);
const essays = filterSection?.posts?.filter(
  (p) => p.category !== "ガイド" && p.category !== "Guides"
) ?? [];
const guides = sections
  .flatMap((s) => s.posts)
  .filter((p) => p.category === "ガイド" || p.category === "Guides");
---

<BlogIndexTemplate
  locale={locale}
  t={t}
  base={base}
  blogPath={blogPath}
  essays={essays}
  guides={guides}
/>
