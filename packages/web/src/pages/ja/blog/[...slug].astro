---
import BlogArticleTemplate from "../../../templates/BlogArticleTemplate.astro";
import { getAllPosts, getPostNavigation, getRelatedPosts } from "../../../data/blog";
import { getTranslations } from "../../../i18n/translations";

export async function getStaticPaths() {
  const posts = await getAllPosts("ja");
  const paths = await Promise.all(
    posts.map(async (post) => ({
      params: { slug: post.slug },
      props: {
        post,
        navigation: await getPostNavigation(post.slug, "ja"),
        related: await getRelatedPosts(post.slug, "ja", 5),
      },
    })),
  );
  return paths;
}

interface Props {
  post: import("../../../data/blog").BlogPost;
  navigation: import("../../../data/blog").PostNavigation;
  related: import("../../../data/blog").BlogPost[];
}

const { post, navigation, related } = Astro.props;
const locale = "ja" as const;
const t = getTranslations(locale);
const base = "/ja";
const blogPath = "/ja/blog";
---

<BlogArticleTemplate
  locale={locale}
  t={t}
  base={base}
  blogPath={blogPath}
  post={post}
  navigation={navigation}
  related={related}
  partnerCtaTitle="パートナープログラム"
  partnerCtaDesc="Lemmaの検証済み属性を組織に導入してみませんか？パートナー候補として登録してください。原則1営業日以内にご返信いたします。"
  partnerCtaButton="パートナー候補として登録"
  relatedLabel="関連記事"
/>
