---
import IndexTemplate from "../../templates/IndexTemplate.astro";
import { getBlogSections } from "../../data/blog";
import { getTranslations } from "../../i18n/translations";

const locale = "ja";
const t = getTranslations(locale);
const base = "/ja";
const sections = await getBlogSections(locale);
const essays = sections.find((s) => s.section === "Essays")?.posts ?? [];
const featured = essays.slice(0, 3);
const mini = essays.slice(3, 7);

const featureGuideLinks = [
  "/ja/blog/encrypt-everything-expose-nothing",
  "/ja/blog/prove-facts-with-zero-knowledge",
  "/ja/blog/disclose-only-what-ai-needs",
  "/ja/blog/query-verified-attributes",
  "/ja/blog/define-your-domain-as-a-schema",
  "/ja/blog/provenance-that-never-disappears",
];
---

<IndexTemplate
  locale={locale}
  t={t}
  base={base}
  description={t.layout.defaultDescription}
  featured={featured}
  mini={mini}
  blogSectionTitle={t.index.essays.h2}
  blogSectionDesc={t.index.essays.p}
  featureGuideLinks={featureGuideLinks}
/>
