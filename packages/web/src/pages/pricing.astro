<script is:inline>
  var io = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (e) {
        if (!e.isIntersecting) return;
        e.target.classList.add("on");
        e.target.querySelectorAll(".plan-card, .dev-plan, .faq-item").forEach(function (c, i) {
          setTimeout(function () {
            c.classList.add("on");
          }, i * 80);
        });
        io.unobserve(e.target);
      });
    },
    { threshold: 0.06, rootMargin: "0px 0px -24px 0px" },
  );
  document.querySelectorAll(".reveal, .plan-card, .dev-plan, .faq-item").forEach(function (el) {
    io.observe(el);
  });
</script>
