---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import BlogList from "../../components/BlogList.astro";
import { getBlogSections } from "../../data/blog";

const sections = getBlogSections();
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Blog — Lemma Oracle"
  description="Essays, changelog, and field notes from Lemma Oracle."
>
  <div class="relative min-h-screen bg-[#FAFAF8]">
    <Navigation />
    <main class="relative pt-14 pb-16">
      <div class="mx-auto max-w-[1400px] px-8 pt-16">
        <h1 class="mb-4 font-mono text-[11px] tracking-wider text-black/30 uppercase">Blog</h1>
        <p class="mb-12 font-mono text-[13px] text-black/60">Essays, changelog, and field notes.</p>
      </div>
      <BlogList sections={sections} />
    </main>
    <footer class="border-t border-black/5 py-8">
      <div class="mx-auto max-w-[1400px] px-8">
        <p class="font-mono text-[10px] tracking-wide text-black/30">
          © 2026 Lemma Oracle — Built for decisions that matter
        </p>
      </div>
    </footer>
  </div>
</Layout>
