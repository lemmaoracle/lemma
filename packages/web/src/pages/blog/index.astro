---
import BlogIndexTemplate from "../../templates/BlogIndexTemplate.astro";
import { getBlogSections } from "../../data/blog";
import { getTranslations } from "../../i18n/translations";

const locale = "en";
const t = getTranslations(locale);
const base = "";
const blogPath = "/blog";
const sections = await getBlogSections(locale);
const essays = sections.find(s => s.section === "Essays")?.posts?.filter(p => p.category !== "Guides") ?? [];
const guides = sections.flatMap(s => s.posts).filter(p => p.category === "Guides");
---

<BlogIndexTemplate
  locale={locale}
  t={t}
  base={base}
  blogPath={blogPath}
  essays={essays}
  guides={guides}
/>
