---
import BlogArticleTemplate from "../../templates/BlogArticleTemplate.astro";
import { getAllPosts, getPostNavigation, getRelatedPosts } from "../../data/blog";
import { getTranslations } from "../../i18n/translations";

export async function getStaticPaths() {
  const posts = await getAllPosts("en");
  const paths = await Promise.all(
    posts.map(async (post) => ({
      params: { slug: post.slug },
      props: {
        post,
        navigation: await getPostNavigation(post.slug, "en"),
        related: await getRelatedPosts(post.slug, "en", 3),
      },
    })),
  );
  return paths;
}

interface Props {
  post: import("../../data/blog").BlogPost;
  navigation: import("../../data/blog").PostNavigation;
  related: import("../../data/blog").BlogPost[];
}

const { post, navigation, related } = Astro.props;
const locale = "en" as const;
const t = getTranslations(locale);
const base = "";
const blogPath = "/blog";
---

<BlogArticleTemplate
  locale={locale}
  t={t}
  base={base}
  blogPath={blogPath}
  post={post}
  navigation={navigation}
  related={related}
  partnerCtaTitle="Partner Program"
  partnerCtaDesc="Interested in applying Lemma's verified attributes to your organization? Register as a partner candidate — we respond within one business day."
  partnerCtaButton="Register as a partner candidate"
  relatedLabel="Related Essays"
/>
