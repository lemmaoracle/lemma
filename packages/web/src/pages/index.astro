<script is:inline>
  window.addEventListener("load", function () {
    document.getElementById("heroBg").classList.add("ready");
    setTimeout(function () {
      document.getElementById("heroContent").classList.add("visible");
    }, 150);
  });

  var io = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.classList.add("on");
        entry.target.querySelectorAll(".feature-card").forEach(function (c, i) {
          setTimeout(function () {
            c.classList.add("on");
          }, i * 75);
        });
        io.unobserve(entry.target);
      });
    },
    { threshold: 0.08, rootMargin: "0px 0px -30px 0px" },
  );

  document.querySelectorAll(".reveal, .feature-card").forEach(function (el) {
    io.observe(el);
  });
</script>
