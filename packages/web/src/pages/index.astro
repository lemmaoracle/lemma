---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import HubSpotDrawer from "../components/HubSpotDrawer.astro";
import HomeSchemaOrg from "@/components/HomeSchemaOrg";
import { getBlogSections } from "../data/blog";
import { getTranslations } from "../i18n/translations";
import HeroCover from "../assets/cover.jpg";
import ProofBg from "../assets/rag.jpg";

const locale = "en";
const t = getTranslations(locale);
const base = "";
const sections = await getBlogSections(locale);

const essays = sections.find((s) => s.section === "Essays")?.posts ?? [];
const featured = essays.slice(0, 3);
const mini = essays.slice(3, 7);
---

<Layout locale={locale} metaType="home" description={t.layout.defaultDescription}>
  <HomeSchemaOrg description={t.layout.defaultDescription} base={base} />
  <Navigation locale={locale} t={t.nav} base={base} />
  <HubSpotDrawer />

  <main>
    <section class="hero">
      <div class="hero-bg" id="heroBg"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content" id="heroContent">
        <div class="hero-eyebrow">Verifiable AI</div>
        <h1 class="hero-h1">
          Give AI
          <strong>proven facts.</strong>
        </h1>
        <div class="hero-rule"></div>
        <p class="hero-sub">
          Every attribute your AI reads carries permanent provenance — who issued it, which schema
          defined it, how it was proven, and where the proof lives on-chain.
        </p>
        <div class="hero-cta">
          <a href="#" class="btn-primary">Get started</a>
          <a
            href="https://429bpd.share-na2.hsforms.com/2E6_TsCd2RUSdP4fKsuhxzw"
            target="_blank"
            class="btn-ghost"
            id="heroWpBtn">Download Whitepaper</a
          >
        </div>
      </div>
      <div class="hero-scroll">Scroll</div>
    </section>

    <div class="marquee-wrap">
      <div class="marquee-track">
        <div class="marquee-item">
          Verifiable AI <span class="dot">◆</span> ZK-Proven Facts <span class="dot">◆</span> AES-GCM
          Encrypted <span class="dot">◆</span> Selective Disclosure <span class="dot">◆</span> Cryptographic
          Provenance <span class="dot">◆</span> docHash / CID <span class="dot">◆</span> On-chain Anchored
          <span class="dot">◆</span> RAG Policy Layer <span class="dot">◆</span> Zero Knowledge <span
            class="dot">◆</span
          > Permanent Provenance <span class="dot">◆</span>
        </div>
        <div class="marquee-item">
          Verifiable AI <span class="dot">◆</span> ZK-Proven Facts <span class="dot">◆</span> AES-GCM
          Encrypted <span class="dot">◆</span> Selective Disclosure <span class="dot">◆</span> Cryptographic
          Provenance <span class="dot">◆</span> docHash / CID <span class="dot">◆</span> On-chain Anchored
          <span class="dot">◆</span> RAG Policy Layer <span class="dot">◆</span> Zero Knowledge <span
            class="dot">◆</span
          > Permanent Provenance <span class="dot">◆</span>
        </div>
      </div>
    </div>

    <section class="build-section reveal" id="features">
      <div class="build-header">
        <div>
          <div class="section-tag">How it works</div>
          <h2>Build on verified attributes,<br />end to end.</h2>
        </div>
        <p>
          Your AI never touches raw PII. Documents stay encrypted end-to-end — Lemma itself never
          sees plaintext. Control exactly which attributes your AI can access, with full
          cryptographic provenance at every step.
        </p>
      </div>
      <div class="features-wrap">
        <div class="features-rock-bg"></div>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-num">01</div>
            <h3>Encrypt Everything,<br />Expose Nothing</h3>
            <p>
              Lemma keeps every document AES-GCM encrypted — your AI never touches raw PII. Only
              docHash and CID are exposed as stable anchors for provenance.
            </p>
            <a
              href="https://lemma.frame00.com/blog/encrypt-everything-expose-nothing"
              class="feature-link">Read the guide →</a
            >
          </div>
          <div class="feature-card">
            <div class="feature-num">02</div>
            <h3>Prove Facts with<br />Zero Knowledge</h3>
            <p>
              Turn business rules like 'over 18' or 'revenue above threshold' into machine-checkable
              facts. Each verified proof is permanently recorded with its circuit and generator.
            </p>
            <a
              href="https://lemma.frame00.com/blog/prove-facts-with-zero-knowledge"
              class="feature-link">Read the guide →</a
            >
          </div>
          <div class="feature-card">
            <div class="feature-num">03</div>
            <h3>Disclose Only<br />What AI Needs</h3>
            <p>
              Holders selectively reveal just the attributes your model requires for retrieval or
              ranking. The link to the original issuer signature stays intact.
            </p>
            <a
              href="https://lemma.frame00.com/blog/disclose-only-what-ai-needs"
              class="feature-link">Read the guide →</a
            >
          </div>
          <div class="feature-card">
            <div class="feature-num">04</div>
            <h3>Query Verified<br />Attributes</h3>
            <p>
              Ask 'users over 18 in Japan' and get back attributes with full provenance — proof
              status, schema, issuer, generator, and verification method — ready for your RAG policy
              layer.
            </p>
            <a href="https://lemma.frame00.com/blog/query-verified-attributes" class="feature-link"
              >Read the guide →</a
            >
          </div>
          <div class="feature-card">
            <div class="feature-num">05</div>
            <h3>Define Your Domain<br />as a Schema</h3>
            <p>
              Model how your AI retrieves and clusters knowledge — bucket ages, risk scores, regions
              — with typed schemas and normalization. Register ZK circuits and reproducible
              generators.
            </p>
            <a
              href="https://lemma.frame00.com/blog/define-your-domain-as-a-schema"
              class="feature-link">Read the guide →</a
            >
          </div>
          <div class="feature-card">
            <div class="feature-num">06</div>
            <h3>Provenance That<br />Never Disappears</h3>
            <p>
              Document commitments, schemas, issuers, and ZK verification results are anchored
              on-chain. Your RAG index can be rebuilt — the provenance layer stays permanent.
            </p>
            <a
              href="https://lemma.frame00.com/blog/provenance-that-never-disappears"
              class="feature-link">Read the guide →</a
            >
          </div>
        </div>
      </div>
    </section>

    <section class="proof-section reveal">
      <div class="proof-bg"></div>
      <div class="proof-overlay"></div>
      <div class="proof-inner">
        <div class="section-tag" style="color:var(--accent)">Why it matters</div>
        <h2>
          Your RAG index can be rebuilt.
          <strong>The provenance layer stays permanent.</strong>
        </h2>
        <div class="proof-rule"></div>
        <p>
          Prove 'age ≥ 18' without exposing the actual age, name, or address. Your AI gets verified
          answers — never the raw data. The proof lives on-chain. The decision holds.
        </p>
        <a href="https://lemma.frame00.com/blog/lemma-oracle-specs" class="btn-primary"
          >Read the specs</a
        >
        <div class="proof-stats">
          <div class="stat">
            <div class="stat-n">0 <span style="font-size:18px">bytes</span></div>
            <div class="stat-l">Raw PII to AI</div>
          </div>
          <div class="stat">
            <div class="stat-n">∞</div>
            <div class="stat-l">Provenance persistence</div>
          </div>
          <div class="stat">
            <div class="stat-n">ZK</div>
            <div class="stat-l">Proof without disclosure</div>
          </div>
        </div>
      </div>
    </section>

    <section class="essays-section reveal" id="essays">
      <div class="essays-header">
        <div>
          <div class="section-tag">Essays</div>
          <h2>Thought and implementation<br />of Verifiable AI.</h2>
        </div>
        <p>
          ZK proofs, cryptographic provenance, selective disclosure.<br />Where technology and
          decision-making intersect.
        </p>
      </div>

      <div class="essays-featured">
        <a href="https://lemma.frame00.com/blog/ai-explainability-management-crypto-proof" class="essay-card-lg">
          <div class="essay-thumb-ph" style="background-image:url('https://raw.githubusercontent.com/lemmaoracle/posts/main/assets/7ewkO-JbRiE.jpg')"></div>
          <div class="essay-body-lg">
            <div class="essay-meta">
              <span class="essay-cat">Business Strategy</span>
              <span class="essay-date-txt">2026.04.16</span>
            </div>
            <h3>"Explainable Management" Powered by Cryptographic Proofs</h3>
            <p>As AI decision-making becomes widespread, 'explainability' — the ability to retrospectively prove the basis for decisions — has become a critical management issue.</p>
          </div>
        </a>
        <div class="essay-aside">
          <a href="https://lemma.frame00.com/blog/verified-attributes-travel-public-services" class="essay-card-sm">
            <div class="essay-meta"><span class="essay-cat">Human Impact</span><span class="essay-date-txt">2026.04.07</span></div>
            <h3 style="font-family:var(--font-display);font-size:17px;font-weight:600;line-height:1.3;color:var(--black)">Verified Attributes in Travel and Public Services</h3>
          </a>
          <a href="https://lemma.frame00.com/blog/privacy-preserving-attribute-marketing-lemma-verifiable-ai" class="essay-card-sm">
            <div class="essay-meta"><span class="essay-cat">Business Strategy</span><span class="essay-date-txt">2026.04.01</span></div>
            <h3 style="font-family:var(--font-display);font-size:17px;font-weight:600;line-height:1.3;color:var(--black)">Privacy-Preserving Attribute Marketing</h3>
          </a>
        </div>
      </div>

      <div class="essays-list" style="margin-top:2px">
        {mini.map((post) => (
          <a href={`/blog/${post.slug}`} class="essay-card-mini">
            <div class="essay-meta">
              <span class="essay-cat">{post.category}</span>
              <span class="essay-date-txt">{post.date}</span>
            </div>
            <h3>{post.title}</h3>
          </a>
        ))}
      </div>
    </section>

    <section class="cta-section reveal">
      <div class="cta-eyebrow">A reasoning engine for long-horizon decisions</div>
      <h2>Built for decisions<br /><em>that matter.</em></h2>
      <div class="cta-rule"></div>
      <p>Closed partner program.<br />Register in under a minute.</p>
      <a href="#" class="btn-cta">Get started</a>
      <a href="https://429bpd.share-na2.hsforms.com/2E6_TsCd2RUSdP4fKsuhxzw" class="btn-cta-outline" id="indexWpBtn" target="_blank" style="display:inline-block;margin-top:14px;background:transparent;color:rgba(255,255,255,.65);padding:15px 44px;font-size:12px;font-weight:400;letter-spacing:.16em;text-transform:uppercase;border:1px solid rgba(255,255,255,.28);cursor:pointer;transition:border-color .2s,color .2s;">Download Whitepaper</a>
    </section>
  </main>

  <Footer locale={locale} t={t.nav} base={base} />
</Layout>

<style define:vars={{ heroBg: `url(${HeroCover.src})`, proofBg: `url(${ProofBg.src})` }}>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 680px;
    display: flex;
    align-items: center;
    padding: 0 10%;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: var(--heroBg) center/cover no-repeat;
    background-position: center 40%;
    filter: saturate(0.42) brightness(0.8);
    transform: scale(1.04);
    transition: transform 10s ease-out;
  }
  .hero-bg.ready {
    transform: scale(1);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(108deg, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.55) 52%, rgba(0,0,0,0.15) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 620px;
    opacity: 0;
    transform: translateY(22px);
    transition: opacity 0.95s ease, transform 0.95s ease;
  }
  .hero-content.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--accent);
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(54px, 6.8vw, 86px);
    font-weight: 300;
    color: #fff;
    line-height: 1.06;
    letter-spacing: -0.01em;
    margin-bottom: 28px;
  }
  .hero-h1 strong {
    font-weight: 600;
    display: block;
  }
  .hero-rule {
    width: 40px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 28px;
  }
  .hero-sub {
    font-size: 15px;
    font-weight: 300;
    color: rgba(255,255,255,0.62);
    line-height: 1.82;
    max-width: 500px;
    margin-bottom: 48px;
  }
  .hero-cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: #fff;
    color: #000;
    padding: 14px 32px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: background 0.2s, color 0.2s;
  }
  .btn-primary:hover {
    background: var(--accent);
    color: #fff;
  }
  .btn-ghost {
    background: transparent;
    color: rgba(255,255,255,0.65);
    padding: 13px 30px;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.28);
    border-radius: 0;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.6);
    color: #fff;
  }
  .hero-scroll {
    position: absolute;
    bottom: 36px;
    right: 5%;
    z-index: 2;
    color: rgba(255,255,255,0.28);
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-scroll::after {
    content: '';
    width: 1px;
    height: 52px;
    background: rgba(255,255,255,0.15);
    animation: lineAnim 2.4s ease-in-out infinite;
  }
  @keyframes lineAnim {
    0%, 100% { opacity: 0.35; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(0.6); }
  }

  .marquee-wrap {
    background: #000;
    padding: 16px 0;
    overflow: hidden;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    animation: scrollLeft 32s linear infinite;
  }
  .marquee-item {
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 0 36px;
    color: rgba(255, 255, 255, 0.26);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .marquee-item .dot {
    color: var(--accent);
    font-size: 7px;
  }
  @keyframes scrollLeft {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .build-section {
    background: #fff;
    padding: 140px 10%;
  }
  .build-header {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 80px;
    align-items: end;
    margin-bottom: 80px;
  }
  .build-header h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 50px);
    font-weight: 400;
    line-height: 1.14;
    color: #000;
  }
  .build-header p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--gray-500);
    max-width: 480px;
  }

  .features-wrap {
    position: relative;
  }
  .features-rock-bg {
    position: absolute;
    inset: 0;
    background: url("https://images.unsplash.com/photo-1504699439244-a032f59b5cbc?auto=format&fit=crop&w=800&q=80")
      center/cover no-repeat;
    filter: saturate(0.25) brightness(0.4);
    opacity: 0.12;
    pointer-events: none;
  }
  .features-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    background: var(--gray-200);
  }
  .feature-card {
    background: #fff;
    padding: 48px 40px;
    border-top: 2px solid transparent;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease, border-color 0.25s;
  }
  .feature-card.on {
    opacity: 1;
    transform: translateY(0);
  }
  .feature-card:nth-child(2) {
    transition-delay: 0.07s;
  }
  .feature-card:nth-child(3) {
    transition-delay: 0.14s;
  }
  .feature-card:nth-child(4) {
    transition-delay: 0.21s;
  }
  .feature-card:nth-child(5) {
    transition-delay: 0.28s;
  }
  .feature-card:nth-child(6) {
    transition-delay: 0.35s;
  }
  .feature-card:hover {
    border-top-color: var(--accent);
  }
  .feature-num {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: 0.12em;
    margin-bottom: 20px;
  }
  .feature-card h3 {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 600;
    line-height: 1.28;
    color: #000;
    margin-bottom: 14px;
  }
  .feature-card p {
    font-size: 14px;
    line-height: 1.78;
    color: #4a4a4a;
    flex: 1;
    margin-bottom: 26px;
  }
  .feature-link {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.2s;
  }
  .feature-link:hover {
    gap: 10px;
  }

  .proof-section {
    position: relative;
    padding: 160px 10%;
    overflow: hidden;
  }
  .proof-bg {
    position: absolute;
    inset: 0;
    background: var(--proofBg) center/cover no-repeat;
    filter: saturate(0.7) brightness(0.65);
  }
  .proof-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.62);
  }
  .proof-inner {
    position: relative;
    z-index: 2;
    max-width: 580px;
  }
  .proof-inner h2 {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 60px);
    font-weight: 300;
    line-height: 1.1;
    color: #fff;
    margin-bottom: 8px;
  }
  .proof-inner h2 strong {
    font-weight: 600;
    display: block;
  }
  .proof-rule {
    width: 40px;
    height: 1px;
    background: var(--accent);
    margin: 28px 0;
  }
  .proof-inner p {
    font-size: 15px;
    line-height: 1.78;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: 48px;
  }
  .proof-stats {
    display: flex;
    gap: 48px;
    margin-top: 56px;
    flex-wrap: wrap;
  }
  .stat {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 18px;
    min-width: 100px;
  }
  .stat-n {
    font-family: var(--font-display);
    font-size: 34px;
    font-weight: 300;
    color: #fff;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-l {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  .essays-section { background: var(--gray-50); padding: 140px 10%; }
  .essays-header { display: grid; grid-template-columns: 1fr 2fr; gap: 80px; align-items: end; margin-bottom: 64px; }
  .essays-header h2 { font-family: var(--font-display); font-size: clamp(32px, 3.5vw, 46px); font-weight: 400; line-height: 1.2; color: var(--black); }
  .essays-header p { font-size: 14px; line-height: 1.8; color: var(--gray-500); max-width: 480px; }

  .essays-featured { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2px; background: var(--gray-200); margin-bottom: 2px; }
  .essay-card-lg { background: var(--white); overflow: hidden; display: grid; grid-template-rows: 260px 1fr; }
  .essay-thumb-ph { width: 100%; height: 100%; background-size: cover; background-position: center; filter: saturate(0.4) brightness(0.85); }
  .essay-body-lg { padding: 32px 36px 36px; border-top: 2px solid var(--accent); }
  .essay-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .essay-cat { font-size: 10px; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); }
  .essay-date-txt { font-size: 10px; color: var(--gray-500); letter-spacing: 0.05em; }
  .essay-card-lg h3 { font-family: var(--font-display); font-size: 20px; font-weight: 600; line-height: 1.3; color: var(--black); margin-bottom: 12px; }
  .essay-card-lg p { font-size: 13px; line-height: 1.75; color: var(--gray-500); }
  .essay-aside { display: flex; flex-direction: column; gap: 2px; background: var(--gray-200); }
  .essay-card-sm { background: var(--white); padding: 28px 32px; border-top: 2px solid transparent; flex: 1; transition: border-color 0.2s; display: flex; flex-direction: column; gap: 10px; text-decoration: none; }
  .essay-card-sm:hover { border-top-color: var(--accent); }
  .essay-card-sm h3 { font-family: var(--font-display); font-size: 17px; font-weight: 600; line-height: 1.3; color: var(--black); }
  .essays-list { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; background: var(--gray-200); }
  .essay-card-mini { background: var(--white); padding: 28px 28px 32px; border-top: 2px solid transparent; transition: border-color 0.2s; display: flex; flex-direction: column; gap: 8px; text-decoration: none; }
