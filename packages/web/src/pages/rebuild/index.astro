---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";

const base = import.meta.env.BASE_URL;
const repo = "lemmaoracle/lemma";
const workflowFile = "deploy-pages.yml";
const workflowUrl = `https://github.com/${repo}/actions/workflows/${encodeURIComponent(workflowFile)}`;
const apiUrl = `https://api.github.com/repos/${repo}/dispatches`;
---

<Layout
  title="Rebuild site — Lemma Oracle"
  description="Trigger GitHub Actions to rebuild and redeploy the site."
>
  <div class="relative min-h-screen bg-[#FAFAF8]">
    <Navigation />
    <main class="relative pt-14 pb-16">
      <div class="mx-auto max-w-[640px] px-8 pt-16">
        <h1 class="mb-6 font-mono text-[24px] tracking-wide">Rebuild site</h1>
        <p class="mb-8 font-mono text-[13px] leading-relaxed text-black/60">
          This page is not linked from the site. Use it to trigger a rebuild and redeploy of the
          static site (e.g. after updating content in Affine).
        </p>

        <h2 class="mb-3 font-mono text-[11px] tracking-wider text-black/40 uppercase">
          Option 1: Run workflow in GitHub
        </h2>
        <p class="mb-4 font-mono text-[13px] text-black/60">
          Open the workflow page and click <strong>Run workflow</strong>.
        </p>
        <a
          href={workflowUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-[13px] text-black/70 underline hover:opacity-70"
        >
          {workflowUrl}
        </a>

        <h2 class="mt-10 mb-3 font-mono text-[11px] tracking-wider text-black/40 uppercase">
          Option 2: Trigger via URL (repository_dispatch)
        </h2>
        <p class="mb-4 font-mono text-[13px] text-black/60">
          From a script or external service (e.g. after Affine updates), send a POST request with a
          Personal Access Token (PAT). This site is static, so a plain GET to this page cannot start
          the workflow without credentials.
        </p>
        <pre
          class="mb-4 overflow-x-auto rounded bg-black/5 p-4 font-mono text-[11px]"><code>curl -X POST \
  -H "Authorization: token $PAT" \
  -H "Accept: application/vnd.github.v3+json" \
  {apiUrl} \
  -d '{{"event_type":"rebuild"}}'</code></pre>
        <p class="font-mono text-[11px] text-black/50">
          Store the PAT in your environment or a secret store; do not commit it. The workflow
          listens for <code>event_type: rebuild</code>.
        </p>

        <p class="mt-10 font-mono text-[11px] text-black/40">
          <a href={base} class="underline">← Back to home</a>
        </p>
      </div>
    </main>
    <footer class="mt-16 border-t border-black/5 py-8">
      <div class="mx-auto max-w-[1400px] px-8">
        <p class="font-mono text-[10px] tracking-wide text-black/30">
          © 2026 Lemma Oracle — Built for decisions that matter
        </p>
      </div>
    </footer>
  </div>
</Layout>
