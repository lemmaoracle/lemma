---
import type { Translations } from "../i18n/translations";
import { ProvenanceChainBg } from "./ProvenanceChainBg";

interface Props {
  t: Translations["masthead"];
  locale: "en" | "ja";
}

const { t, locale } = Astro.props;
---

<section class="relative flex min-h-[85vh] flex-col items-center justify-center px-8 py-24">
  {/* Provenance Chain animated background */}
  <ProvenanceChainBg client:load />

  {/* Centered title and subtitle */}
  <div class="relative z-10 max-w-175 text-center">
    <h1
      class="mb-6 text-8xl leading-[1.1] tracking-[-0.02em]"
      style="font-family: 'Instrument Serif', serif;"
    >
      {t.title}
    </h1>
    <p class="mx-auto mb-8 max-w-150 font-mono text-sm leading-relaxed tracking-wide text-black/60">
      {t.tagline}
    </p>

    {/* CTA button */}
    <div class="flex items-center justify-center">
      <a
        href={locale === "ja" ? "/ja/blog" : "/blog"}
        class="border border-black bg-black px-6 py-3 font-mono text-xs tracking-wide text-white uppercase transition-colors hover:bg-black/90"
      >
        {t.ctaGetStarted}
      </a>
    </div>
  </div>
</section>
