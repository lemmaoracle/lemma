---
import LemmaOracle from "./LemmaOracle.astro";
---

<div class="hs-drawer-overlay" id="hsOverlay"></div>
<div class="hs-drawer" id="hsDrawer" role="dialog" aria-modal="true">
  <div class="hs-drawer-header">
    <LemmaOracle class="h-[22px] w-auto text-white" />
    <button class="hs-drawer-close" id="hsDrawerClose" aria-label="Close">&#x2715;</button>
  </div>
  <div class="hs-drawer-body">
    <div class="hs-drawer-title" id="hsDrawerTitle">Built for decisions<br><em>that matter.</em></div>
    <div class="hs-drawer-subtitle" id="hsDrawerSub">Register as a partner candidate or get in touch about enterprise plans. We respond within one business day.</div>
    <div id="hsFormContainer"></div>
  </div>
</div>

<script is:inline>
  (function() {
    var PORTAL = '245659009';
    var FORM_ID = '13afd3b0-2776-4544-9d3f-87cab2e871cf';
    var formLoaded = false;

    function loadHsScript(cb) {
      if (window.hbspt) { cb(); return; }
      var s = document.createElement('script');
      s.src = '//js.hsforms.net/forms/embed/v2.js';
      s.charset = 'utf-8';
      s.onload = cb;
      document.head.appendChild(s);
    }

    function createForm() {
      if (formLoaded) return;
      formLoaded = true;
      window.hbspt.forms.create({
        region: 'na2',
        portalId: PORTAL,
        formId: FORM_ID,
        target: '#hsFormContainer',
        onFormSubmitted: function() {
          document.getElementById('hsFormContainer').innerHTML =
            '<div class="hs-drawer-submitted"><p>Thank you.<br>We\'ll be in touch soon.</p><small>lemma.frame00.com</small></div>';
        }
      });
    }

    function openDrawer() {
      var overlay = document.getElementById('hsOverlay');
      var drawer  = document.getElementById('hsDrawer');
      overlay.classList.add('open');
      drawer.classList.add('open');
      requestAnimationFrame(function() { overlay.classList.add('visible'); });
      document.body.style.overflow = 'hidden';
      loadHsScript(createForm);
    }

    function closeDrawer() {
      var overlay = document.getElementById('hsOverlay');
      var drawer  = document.getElementById('hsDrawer');
      overlay.classList.remove('visible');
      drawer.classList.remove('open');
      setTimeout(function() { overlay.classList.remove('open'); }, 300);
      document.body.style.overflow = '';
    }

    document.getElementById('hsDrawerClose').addEventListener('click', closeDrawer);
    document.getElementById('hsOverlay').addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDrawer(); });

    var CTA = ['talk to us','get started','register','download for free','partner'];
    function isCta(el) {
      var txt = el.textContent.trim().toLowerCase();
      return CTA.some(function(t) { return txt.indexOf(t) !== -1; });
    }
    document.querySelectorAll('a[class*="btn"], button[class*="btn"], .btn-plan').forEach(function(el) {
      if (isCta(el) && el.textContent.toLowerCase().indexOf('waitlist') === -1
                    && el.textContent.toLowerCase().indexOf('specs') === -1
                    && el.textContent.toLowerCase().indexOf('guide') === -1
                    && el.textContent.toLowerCase().indexOf('read') === -1) {
        el.addEventListener('click', function(e) { e.preventDefault(); openDrawer(); });
      }
    });
  })();
</script>

<style>
  .hs-drawer-overlay {
    display: none; position: fixed; inset: 0; z-index: 2000;
    background: rgba(0,0,0,0.55); opacity: 0;
    transition: opacity .3s ease;
  }
  .hs-drawer-overlay.open { display: block; }
  .hs-drawer-overlay.visible { opacity: 1; }
  .hs-drawer {
    position: fixed; top: 0; right: 0; bottom: 0; z-index: 2001;
    width: min(480px,100vw); background: #fff;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: -4px 0 32px rgba(0,0,0,0.18);
  }
  .hs-drawer.open { transform: translateX(0); }
  .hs-drawer-header {
    background: #000; padding: 20px 28px;
    display: flex; align-items: center; justify-content: space-between;
    flex-shrink: 0;
  }
  .hs-drawer-close {
    background: none; border: none; cursor: pointer;
    color: rgba(255,255,255,.5); font-size: 22px; line-height: 1;
    transition: color .2s; padding: 4px;
  }
  .hs-drawer-close:hover { color: #fff; }
  .hs-drawer-body { flex: 1; overflow-y: auto; padding: 36px 28px 40px; }
  .hs-drawer-title {
    font-family: var(--font-display);
    font-size: 28px; font-weight: 300; color: #000;
    line-height: 1.15; margin-bottom: 8px;
  }
  .hs-drawer-title em { font-style: italic; }
  .hs-drawer-subtitle {
    font-size: 13px; color: #9E9E9E; line-height: 1.7; margin-bottom: 28px;
    padding-bottom: 24px; border-bottom: 1px solid #E0E0E0;
  }
  .hs-drawer-body :global(.hs-form fieldset) { max-width: 100% !important; }
  .hs-drawer-body :global(.hs-form .hs-input) {
    width: 100% !important; border-radius: 0 !important;
    border: 1px solid #E0E0E0 !important;
    font-size: 14px !important; padding: 10px 14px !important;
    transition: border-color .2s !important; box-sizing: border-box !important;
  }
  .hs-drawer-body :global(.hs-form .hs-input:focus) {
    border-color: #000 !important; outline: none !important;
  }
  .hs-drawer-body :global(.hs-form .hs-button) {
    background: #000 !important; color: #fff !important;
    border: none !important; border-radius: 0 !important;
    padding: 14px 32px !important; font-size: 12px !important;
    font-weight: 500 !important; letter-spacing: .12em !important;
    text-transform: uppercase !important; cursor: pointer !important;
    transition: background .2s !important; width: 100% !important;
    margin-top: 8px !important;
  }
  .hs-drawer-body :global(.hs-form .hs-button:hover) { background: #8B4513 !important; }
  .hs-drawer-body :global(.hs-form label) {
    font-size: 11px !important; font-weight: 500 !important;
    letter-spacing: .08em !important; text-transform: uppercase !important;
    color: #9E9E9E !important; margin-bottom: 6px !important; display: block !important;
  }
  .hs-drawer-body :global(.hs-form .hs-form-field) { margin-bottom: 18px !important; }
  .hs-drawer-body :global(.hs-error-msgs li) { font-size: 11px !important; color: #c0392b !important; list-style: none !important; }
  .hs-drawer-submitted { text-align: center; padding: 48px 20px; }
  .hs-drawer-submitted p {
    font-family: var(--font-display);
    font-size: 24px; font-weight: 300; color: #000; line-height: 1.5;
    margin-bottom: 12px;
  }
  .hs-drawer-submitted small { font-size: 13px; color: #9E9E9E; }
</style>
