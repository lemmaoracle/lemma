---
import BlogEntry from "./BlogEntry.astro";
import type { BlogSection as BlogSectionType } from "../data/blog";

interface Props {
  sections: ReadonlyArray<BlogSectionType>;
}

const { sections } = Astro.props;
---

<div class="mx-auto max-w-[1400px] px-8 py-16">
  {
    sections.map((section) => (
      <section class="mb-20 last:mb-0">
        <h2 class="mb-8 border-b border-black/10 pb-3 font-mono text-[11px] tracking-wider text-black/30 uppercase">
          {section.section}
        </h2>
        <div>
          {section.posts.map((post) => (
            <BlogEntry
              slug={post.slug}
              date={post.date}
              category={post.category}
              title={post.title}
              abstract={post.abstract}
              categoryColor={post.categoryColor}
            />
          ))}
        </div>
      </section>
    ))
  }
</div>
