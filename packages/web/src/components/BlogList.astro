---
import BlogEntry from "./BlogEntry.astro";
import type { BlogSection as BlogSectionType } from "../data/blog";
import type { Translations } from "../i18n/translations";

interface Props {
  sections: ReadonlyArray<BlogSectionType>;
  t: Translations["blog"];
  base: string;
}

const { sections, t, base } = Astro.props;
---

<div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 sm:py-12 lg:px-8 lg:py-16">
  {
    sections.map((section) => {
      const sectionLabel = t.sections[section.section] ?? section.section;
      return (
        <section class="mb-20 last:mb-0">
          <h2
            id={section.section.toLowerCase().replace(/\s+/g, "-")}
            class="mb-6 border-b border-black/10 pb-2 font-mono text-xs tracking-wider text-black/30 uppercase sm:mb-8 sm:pb-3"
          >
            {sectionLabel}
          </h2>
          <div>
            {section.posts.map((post) => (
              <BlogEntry
                slug={post.slug}
                date={post.date}
                category={post.category}
                title={post.title}
                abstract={post.abstract}
                categoryColor={post.categoryColor}
                cover={post.cover}
                base={base}
              />
            ))}
          </div>
        </section>
      );
    })
  }
</div>
