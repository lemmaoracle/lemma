---
import type { Locale } from "../i18n/translations";
import type { Translations } from "../i18n/translations";
import LemmaOracle from "./LemmaOracle.astro";

interface Props {
  locale: Locale;
  t: Translations["nav"];
  base: string;
}

const { locale, t, base } = Astro.props;
const blogPath = base ? `${base}/blog` : "/blog";
const faqPath = "/faq";
const pricingPath = "/pricing";
const servicesPath = "/services";
const homePath = base || "/";

const currentPath = Astro.url.pathname;
const languageSwitchHref =
  locale === "ja"
    ? currentPath.replace(/^\/ja/, "") || "/"
    : `/ja${currentPath}`;

const isActive = (path: string) => {
  if (path === "/" && currentPath === "/") return true;
  if (path !== "/" && currentPath.startsWith(path)) return true;
  return false;
};
---

<nav class="mega-nav" id="mainNav">
  <a href={homePath} class="mega-nav-logo">
    <LemmaOracle class="h-[26px] w-auto text-white" />
  </a>

  <!-- DESKTOP LINKS -->
  <ul class="mega-nav-links">
    <li class="mega-nav-item">
      <button class="mega-nav-link has-mega" data-key="services">{t.services}</button>
      <div class="mega-panel">
        <div class="mega-section mega-two-col">
          <div class="mega-section-label">{t.mega.services.enterprise}</div>
          <div class="mega-links">
            <a href={servicesPath} class="mega-link">
              <span class="mega-link-title">{t.mega.services.civic}</span>
              <span class="mega-link-sub">{t.mega.services.civicSub}</span>
            </a>
            <a href={servicesPath} class="mega-link">
              <span class="mega-link-title">{t.mega.services.critical}</span>
              <span class="mega-link-sub">{t.mega.services.criticalSub}</span>
            </a>
            <a href={servicesPath} class="mega-link">
              <span class="mega-link-title">{t.mega.services.compliance}</span>
              <span class="mega-link-sub">{t.mega.services.complianceSub}</span>
            </a>
            <a href={`${servicesPath}#solution`} class="mega-link">
              <span class="mega-link-title">{t.mega.services.howItWorks}</span>
              <span class="mega-link-sub">{t.mega.services.howItWorksSub}</span>
            </a>
          </div>
        </div>
        
        {locale === 'ja' && (
        <div class="mega-section">
          <div class="mega-section-label">{t.mega.services.materials}</div>
          <div class="mega-links">
            <a href="https://429bpd.share-na2.hsforms.com/2RxuIcA8OSYyAcsEKpxTM9Q" class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.services.whitepaper}</span>
              <span class="mega-link-sub">{t.mega.services.whitepaperSub}</span>
            </a>
          </div>
        </div>
        )}

        <div class="mega-x402">
          <div class="mega-x402-label">{t.mega.services.developer}</div>
          <div class="mega-x402-title">{t.mega.services.trust402Demo}</div>
          {t.mega.services.trust402Sub && <div class="mega-x402-sub">{t.mega.services.trust402Sub}</div>}
          <div class="mega-x402-links">
            <a href="#" class="mega-x402-link">{t.mega.services.tryDemo}</a>
            {locale === 'en' && <a href="#" class="mega-x402-link">{t.mega.services.joinWaitlist}</a>}
          </div>
        </div>
      </div>
    </li>

    <li class="mega-nav-item">
      <button class="mega-nav-link has-mega" data-key="pricing">{t.pricing}</button>
      <div class="mega-panel">
        <div class="mega-section">
          <div class="mega-section-label">{t.mega.pricing.enterprise}</div>
          <div class="mega-links">
            <a href={pricingPath} class="mega-link">
              <span class="mega-link-title">{t.mega.pricing.civic}</span>
              <span class="mega-link-sub">{t.mega.pricing.civicSub}</span>
            </a>
            <a href={pricingPath} class="mega-link">
              <span class="mega-link-title">{t.mega.pricing.critical}</span>
              <span class="mega-link-sub">{t.mega.pricing.criticalSub}</span>
            </a>
            <a href={pricingPath} class="mega-link">
              <span class="mega-link-title">{t.mega.pricing.compliance}</span>
              <span class="mega-link-sub">{t.mega.pricing.complianceSub}</span>
            </a>
          </div>
        </div>
        <div class="mega-section">
          <div class="mega-section-label">{t.mega.pricing.developer}</div>
          <div class="mega-links">
            <a href={pricingPath} class="mega-link">
              <span class="mega-link-title">{t.mega.pricing.trust402}</span>
              <span class="mega-link-sub">{t.mega.pricing.trust402Sub}</span>
            </a>
          </div>
        </div>
      </div>
    </li>

    <li class="mega-nav-item">
      <button class="mega-nav-link has-mega" data-key="developers">{t.developers}</button>
      <div class="mega-panel right">
        <div class="mega-section">
          <div class="mega-section-label">{t.mega.developers.architecture}</div>
          <div class="mega-links">
            <a href={`${blogPath}/lemma-oracle-specs`} class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.developers.specs}</span>
              <span class="mega-link-sub">{t.mega.developers.specsSub}</span>
            </a>
          </div>
        </div>
        <div class="mega-section">
          <div class="mega-section-label">{t.mega.developers.guides}</div>
          <div class="mega-links">
            <a href={`${blogPath}/encrypt-everything-expose-nothing`} class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.developers.encrypt}</span>
              <span class="mega-link-sub">{t.mega.developers.encryptSub}</span>
            </a>
            <a href={`${blogPath}/prove-facts-with-zero-knowledge`} class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.developers.prove}</span>
              <span class="mega-link-sub">{t.mega.developers.proveSub}</span>
            </a>
            <a href={`${blogPath}/disclose-only-what-ai-needs`} class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.developers.disclose}</span>
              <span class="mega-link-sub">{t.mega.developers.discloseSub}</span>
            </a>
            {locale === 'en' && (
            <>
              <a href={`${blogPath}/query-verified-attributes`} class="mega-link" target="_blank">
                <span class="mega-link-title">{t.mega.developers.query}</span>
                <span class="mega-link-sub">{t.mega.developers.querySub}</span>
              </a>
              <a href={`${blogPath}/define-your-domain-as-a-schema`} class="mega-link" target="_blank">
                <span class="mega-link-title">{t.mega.developers.define}</span>
                <span class="mega-link-sub">{t.mega.developers.defineSub}</span>
              </a>
            </>
            )}
            <a href={`${blogPath}/provenance-that-never-disappears`} class="mega-link" target="_blank">
              <span class="mega-link-title">{t.mega.developers.provenance}</span>
              <span class="mega-link-sub">{t.mega.developers.provenanceSub}</span>
            </a>
          </div>
        </div>
        <div class="mega-x402">
          <div class="mega-x402-label">{t.mega.developers.x402}</div>
          <div class="mega-x402-title">{t.mega.developers.demoSoon}</div>
          {t.mega.developers.demoSub && <div class="mega-x402-sub">{t.mega.developers.demoSub}</div>}
          <div class="mega-x402-links">
            <a href="#" class="mega-x402-link">{locale === 'en' ? t.mega.developers.joinWaitlist : t.mega.developers.tryDemo}</a>
            <a href={`${blogPath}/lemma-oracle-specs`} class="mega-x402-link" target="_blank">{t.mega.developers.readSpecs}</a>
          </div>
        </div>
      </div>
    </li>

    <li class="mega-nav-item">
      <a href={blogPath} class:list={["mega-nav-link", { active: isActive(blogPath) }]}>{t.blog}</a>
    </li>
    <li class="mega-nav-item">
      <a href={faqPath} class:list={["mega-nav-link", { active: isActive(faqPath) }]}>{t.faq}</a>
    </li>
    <li class="mega-nav-item">
      <a href={languageSwitchHref} class="mega-nav-link nav-lang">
        {locale === "ja" ? t.languageEn : t.languageJa}
      </a>
    </li>
  </ul>

  <!-- HAMBURGER -->
  <button class="nav-hamburger" id="navHamburger" aria-label="Open menu">
    <span></span><span></span><span></span>
  </button>

  <!-- MOBILE DRAWER -->
  <div class="nav-mobile-drawer" id="navMobileDrawer">
    <div class="mob-section">
      <div class="mob-section-header">
        {t.services} <span class="mob-arrow"></span>
      </div>
      <div class="mob-section-body">
        <a href={servicesPath} class="mob-link">{t.mega.services.civic}<small>{t.mega.services.civicSub}</small></a>
        <a href={servicesPath} class="mob-link">{t.mega.services.critical}<small>{t.mega.services.criticalSub}</small></a>
        <a href={servicesPath} class="mob-link">{t.mega.services.compliance}<small>{t.mega.services.complianceSub}</small></a>
        <a href={`${servicesPath}#solution`} class="mob-link">{t.mega.services.howItWorks}<small>{t.mega.services.howItWorksSub}</small></a>
      </div>
    </div>

    <div class="mob-section">
      <div class="mob-section-header">
        {t.pricing} <span class="mob-arrow"></span>
      </div>
      <div class="mob-section-body">
        <a href={pricingPath} class="mob-link">{t.mega.pricing.civic}</a>
        <a href={pricingPath} class="mob-link">{t.mega.pricing.critical}</a>
        <a href={pricingPath} class="mob-link">{t.mega.pricing.compliance}</a>
        <a href={pricingPath} class="mob-link">{t.mega.pricing.trust402}<small>{t.mega.pricing.trust402Sub}</small></a>
      </div>
    </div>

    <div class="mob-section">
      <div class="mob-section-header">
        {t.developers} <span class="mob-arrow"></span>
      </div>
      <div class="mob-section-body">
        <a href={`${blogPath}/lemma-oracle-specs`} class="mob-link" target="_blank">{t.mega.developers.specs}</a>
        <a href={`${blogPath}/encrypt-everything-expose-nothing`} class="mob-link" target="_blank">{t.mega.developers.encrypt}</a>
        <a href={`${blogPath}/prove-facts-with-zero-knowledge`} class="mob-link" target="_blank">{t.mega.developers.prove}</a>
        <a href={`${blogPath}/disclose-only-what-ai-needs`} class="mob-link" target="_blank">{t.mega.developers.disclose}</a>
        {locale === 'en' && (
        <>
          <a href={`${blogPath}/query-verified-attributes`} class="mob-link" target="_blank">{t.mega.developers.query}</a>
          <a href={`${blogPath}/define-your-domain-as-a-schema`} class="mob-link" target="_blank">{t.mega.developers.define}</a>
        </>
        )}
        <a href={`${blogPath}/provenance-that-never-disappears`} class="mob-link" target="_blank">{t.mega.developers.provenance}</a>
      </div>
    </div>

    <a href={blogPath} class="mob-direct">{t.blog}</a>
    <a href={faqPath} class="mob-direct">{t.faq}</a>

    <div class="mob-cta">
      <a href={locale === 'ja' ? 'https://429bpd.share-na2.hsforms.com/2RxuIcA8OSYyAcsEKpxTM9Q' : '#'} class="mob-cta-btn" target={locale === 'ja' ? '_blank' : '_self'}>{t.mega.mobile.talkToUs}</a>
    </div>

    <div class="mob-lang">
      <a href={languageSwitchHref}>{locale === "ja" ? t.languageEn : t.languageJa}</a>
    </div>
  </div>
</nav>

<style>
  .mega-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    background: #000; height: 64px;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 5%;
    border-bottom: 1px solid rgba(255,255,255,.06);
    transition: border-color .3s;
  }
  .mega-nav-logo { display: flex; align-items: center; text-decoration: none; flex-shrink: 0; }

  .mega-nav-links {
    display: flex; align-items: stretch; height: 64px;
    list-style: none; gap: 0; margin: 0; padding: 0;
  }
  .mega-nav-item { position: relative; display: flex; align-items: center; }

  .mega-nav-link {
    color: rgba(255,255,255,.5); font-size: 11px; font-weight: 400;
    letter-spacing: .1em; text-decoration: none; text-transform: uppercase;
    padding: 0 16px; height: 64px; display: flex; align-items: center; gap: 5px;
    transition: color .2s; white-space: nowrap;
    background: none; border: none; cursor: pointer; font-family: inherit;
  }
  .mega-nav-link:hover, .mega-nav-link.active { color: #fff; }
  .mega-nav-link.has-mega::after {
    content: ''; width: 4px; height: 4px;
    border-right: 1px solid currentColor; border-bottom: 1px solid currentColor;
    transform: rotate(45deg) translateY(-2px); display: inline-block;
    opacity: .5; transition: transform .2s;
  }
  .mega-nav-item:hover .mega-nav-link.has-mega::after {
    transform: rotate(-135deg) translateY(-2px); opacity: 1;
  }
  .mega-nav-link.nav-lang {
    color: rgba(255,255,255,.28);
    border-left: 1px solid rgba(255,255,255,.1); margin-left: 8px;
  }

  .mega-panel {
    display: none; position: absolute; top: 64px; left: 0;
    background: #0D0D0D;
    border: 1px solid rgba(255,255,255,.08); border-top: none;
    min-width: 320px; z-index: 999;
  }
  .mega-panel.right { left: auto; right: 0; }
  .mega-nav-item:hover .mega-panel { display: block; }

  .mega-section { padding: 20px 24px; border-bottom: 1px solid rgba(255,255,255,.06); }
  .mega-section:last-child { border-bottom: none; }
  .mega-section-label {
    font-size: 9px; font-weight: 500; letter-spacing: .22em; text-transform: uppercase;
    color: #8B4513; margin-bottom: 14px;
  }
  .mega-links { display: flex; flex-direction: column; gap: 2px; }
  .mega-two-col .mega-links { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
  .mega-link {
    display: flex; flex-direction: column; padding: 10px 12px;
    text-decoration: none; border-left: 2px solid transparent;
    transition: border-color .15s, background .15s;
  }
  .mega-link:hover { border-left-color: #8B4513; background: rgba(255,255,255,.03); }
  .mega-link-title { font-size: 13px; color: rgba(255,255,255,.7); font-weight: 400; line-height: 1; margin-bottom: 3px; }
  .mega-link:hover .mega-link-title { color: #fff; }
  .mega-link-sub { font-size: 11px; color: rgba(255,255,255,.28); line-height: 1.3; }

  .mega-x402 {
    padding: 18px 24px; background: rgba(139,69,19,.07);
    border-top: 1px solid rgba(139,69,19,.15);
  }
  .mega-x402-label { font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: #8B4513; margin-bottom: 8px; }
  .mega-x402-title { font-size: 13px; color: rgba(255,255,255,.7); margin-bottom: 4px; }
  .mega-x402-sub { font-size: 11px; color: rgba(255,255,255,.28); margin-bottom: 12px; }
  .mega-x402-links { display: flex; gap: 8px; }
  .mega-x402-link {
    font-size: 10px; color: #8B4513; border: 1px solid rgba(139,69,19,.4);
    padding: 4px 12px; text-decoration: none; letter-spacing: .08em; text-transform: uppercase;
    transition: background .2s, color .2s;
  }
  .mega-x402-link:hover { background: #8B4513; color: #fff; }

  .nav-hamburger {
    display: none; background: none; border: none; cursor: pointer;
    padding: 8px; flex-direction: column; gap: 5px;
  }
  .nav-hamburger span {
    display: block; width: 22px; height: 1.5px; background: rgba(255,255,255,.7);
    transition: transform .25s, opacity .25s;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .nav-mobile-drawer {
    display: none; position: fixed; top: 64px; left: 0; right: 0; bottom: 0;
    background: #000; z-index: 999; overflow-y: auto;
    transform: translateX(100%); transition: transform .3s cubic-bezier(.4,0,.2,1);
  }
  .nav-mobile-drawer.open { transform: translateX(0); }

  .mob-section { border-bottom: 1px solid rgba(255,255,255,.06); }
  .mob-section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 6%; cursor: pointer;
    font-size: 13px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase;
    color: rgba(255,255,255,.7);
  }
  .mob-section-header .mob-arrow {
    width: 8px; height: 8px;
    border-right: 1px solid rgba(255,255,255,.4); border-bottom: 1px solid rgba(255,255,255,.4);
    transform: rotate(45deg); transition: transform .2s;
    flex-shrink: 0;
  }
  .mob-section.open .mob-section-header .mob-arrow { transform: rotate(-135deg); }
  .mob-section-body { display: none; padding: 0 6% 16px; }
  .mob-section.open .mob-section-body { display: block; }

  .mob-link {
    display: block; padding: 12px 0; text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.04);
    color: rgba(255,255,255,.55); font-size: 14px; line-height: 1.3;
    transition: color .15s;
  }
  .mob-link:last-child { border-bottom: none; }
  .mob-link:hover { color: #fff; }
  .mob-link small { display: block; font-size: 11px; color: rgba(255,255,255,.28); margin-top: 2px; }

  .mob-direct {
    display: block; padding: 18px 6%;
    font-size: 13px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase;
    color: rgba(255,255,255,.7); text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.06);
    transition: color .15s;
  }
  .mob-direct:hover { color: #fff; }

  .mob-cta { padding: 24px 6%; }
  .mob-cta-btn {
    display: block; width: 100%; padding: 16px;
    background: #fff; color: #000; text-align: center;
    font-size: 11px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase;
    border: none; cursor: pointer; text-decoration: none;
    transition: background .2s;
  }
  .mob-cta-btn:hover { background: #8B4513; color: #fff; }

  .mob-lang {
    padding: 16px 6%;
    font-size: 11px; color: rgba(255,255,255,.25); letter-spacing: .08em;
  }
  .mob-lang a { color: rgba(255,255,255,.35); text-decoration: none; }

  @media(max-width:900px) {
    .mega-nav { padding: 0 6%; }
    .mega-nav-links { display: none; }
    .nav-hamburger { display: flex; }
    .nav-mobile-drawer { display: block; }
  }
</style>

<script is:inline>
  (function() {
    window.addEventListener('scroll', function() {
      var nav = document.getElementById('mainNav');
      if (nav) nav.style.borderBottomColor =
        scrollY > 60 ? 'rgba(255,255,255,.12)' : 'rgba(255,255,255,.06)';
    }, { passive: true });

    document.querySelectorAll('.mega-nav-link[data-key]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var map = { services: '/services', pricing: '/pricing' };
        if (map[btn.dataset.key]) location.href = map[btn.dataset.key];
      });
    });

    var ham = document.getElementById('navHamburger');
    var mob = document.getElementById('navMobileDrawer');
    if (ham && mob) {
      ham.addEventListener('click', function() {
        var open = mob.classList.toggle('open');
        ham.classList.toggle('open', open);
        document.body.style.overflow = open ? 'hidden' : '';
      });
    }

    document.querySelectorAll('.mob-section-header').forEach(function(hdr) {
      hdr.addEventListener('click', function() {
        var section = hdr.closest('.mob-section');
        var wasOpen = section.classList.contains('open');
        document.querySelectorAll('.mob-section.open').forEach(function(s) { s.classList.remove('open'); });
        if (!wasOpen) section.classList.add('open');
      });
    });
  })();
</script>
