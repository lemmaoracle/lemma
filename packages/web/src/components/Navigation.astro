---
import type { Locale } from "../i18n/translations";
import type { Translations } from "../i18n/translations";
import LemmaOracle from "./LemmaOracle.astro";

interface Props {
  locale: Locale;
  t: Translations["nav"];
  base: string;
}

const { locale, t, base } = Astro.props;
const blogPath = base ? `${base}/blog` : "/blog";
const faqPath = `${blogPath}/faq`;
const homePath = base || "/";

const currentPath = Astro.url.pathname;
const languageSwitchHref =
  locale === "ja"
    ? currentPath.replace(/^\/ja/, "") || "/"
    : `/ja${currentPath}`;
---

<nav
  class="fixed top-0 right-0 left-0 z-50 border-b border-black/5 bg-[#FAFAF8]/95 backdrop-blur-sm"
  id="main-nav"
>
  <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href={homePath} class="font-mono text-sm tracking-wider text-black/50 uppercase">
      <LemmaOracle class="h-8 w-auto text-black sm:h-10 lg:h-12" />
    </a>
    <ul class="hidden items-center gap-4 text-sm tracking-wide uppercase lg:flex lg:gap-6">
      <li>
        <a href={`${base}/services`} class="transition-opacity hover:opacity-50">{t.services}</a>
      </li>
      <li><a href={homePath} class="opacity-50 transition-opacity">{t.changelog}</a></li>
      <li>
        <a href={`${homePath}#essays`} class="transition-opacity hover:opacity-50">{t.essays}</a>
      </li>
      <li><a href={blogPath} class="transition-opacity hover:opacity-50">{t.blog}</a></li>
      <li><a href={faqPath} class="transition-opacity hover:opacity-50">{t.faq}</a></li>
      <li class="text-black/40">
        {
          locale === "ja" ? (
            <a href={languageSwitchHref} class="transition-opacity hover:opacity-70">
              {t.languageEn}
            </a>
          ) : (
            <a href={languageSwitchHref} class="transition-opacity hover:opacity-70">
              {t.languageJa}
            </a>
          )
        }
      </li>
    </ul>
    <div class="flex items-center lg:hidden">
      <button
        type="button"
        class="text-black/50 hover:text-black/80"
        aria-label="メニュー"
        aria-expanded="false"
        id="mobile-menu-button"
      >
        <!-- Hamburger icon -->
        <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon (hidden by default) -->
        <svg id="menu-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden border-t border-black/5 bg-[#FAFAF8]/98 backdrop-blur-md lg:hidden"
  >
    <ul class="flex flex-col gap-1 px-4 py-4 text-sm tracking-wide uppercase sm:px-6">
      <li>
        <a href={`${base}/services`} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">{t.services}</a>
      </li>
      <li>
        <a href={homePath} class="block rounded-md px-3 py-2.5 text-black/50 transition-colors hover:bg-black/5">{t.changelog}</a>
      </li>
      <li>
        <a href={`${homePath}#essays`} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">{t.essays}</a>
      </li>
      <li>
        <a href={blogPath} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">{t.blog}</a>
      </li>
      <li>
        <a href={faqPath} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">{t.faq}</a>
      </li>
      <li class="mt-2 border-t border-black/5 pt-2 text-black/40">
        {
          locale === "ja" ? (
            <a href={languageSwitchHref} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">
              {t.languageEn}
            </a>
          ) : (
            <a href={languageSwitchHref} class="block rounded-md px-3 py-2.5 transition-colors hover:bg-black/5">
              {t.languageJa}
            </a>
          )
        }
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  (function () {
    const btn = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("menu-icon-open");
    const iconClose = document.getElementById("menu-icon-close");
    if (!btn || !menu || !iconOpen || !iconClose) return;

    btn.addEventListener("click", function () {
      const isOpen = !menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      iconOpen.classList.toggle("hidden");
      iconClose.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", String(!isOpen));
    });

    // Close menu when a link is clicked
    menu.querySelectorAll("a").forEach(function (link) {
      link.addEventListener("click", function () {
        menu.classList.add("hidden");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>
