---
const base = import.meta.env.BASE_URL;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-[#FAFAF8]/95 backdrop-blur-sm border-b border-black/5">
  <div class="max-w-[1400px] mx-auto px-8 py-3 flex items-center justify-between">
    <a href={base} class="font-mono text-[11px] tracking-wider uppercase text-black/50">
      Lemma Oracle
    </a>
    <ul class="flex gap-6 items-center font-mono text-[11px] tracking-wide uppercase">
      <li><a href={`${base}#overview`} class="hover:opacity-50 transition-opacity">Overview</a></li>
      <li><a href={`${base}#changelog`} class="hover:opacity-50 transition-opacity">Changelog</a></li>
      <li><a href={`${base}#essays`} class="hover:opacity-50 transition-opacity">Essays</a></li>
      <li><a href={`${base}#docs`} class="hover:opacity-50 transition-opacity">Docs</a></li>
      <li><a href={`${base}blog`} class="hover:opacity-50 transition-opacity">Blog</a></li>
    </ul>
  </div>
</nav>
