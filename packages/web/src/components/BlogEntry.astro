---
interface Props {
  slug: string;
  date: string;
  category: string;
  title: string;
  abstract: string;
  categoryColor?: string;
  base?: string;
  cover?: string;
}

const {
  slug,
  date,
  category,
  title,
  abstract,
  categoryColor = "#000",
  cover,
  base: baseProp,
} = Astro.props;
const base = baseProp ?? import.meta.env.BASE_URL;
const blogPath = base ? `${base}/blog` : "/blog";
const href = `${blogPath}/${slug}`;
const bgColor = `${categoryColor}15`;
---

<div
  class="group grid cursor-pointer gap-4 border-b border-black/5 py-4 transition-colors hover:bg-black/[0.02] sm:gap-6 sm:py-5 lg:grid-cols-[100px_120px_auto_1fr]"
>
  <div class="pt-1 font-mono text-xs tracking-wide text-black/40">{date}</div>
  <div class="pt-1">
    <span
      class="rounded-sm px-2 py-1 font-mono text-xs tracking-wider uppercase"
      style={`background-color: ${bgColor}; color: ${categoryColor};`}
    >
      {category}
    </span>
  </div>
  <div class="min-w-0 lg:col-span-1">
    <a href={href} class="block">
      <h3
        class="mb-2 text-lg leading-[1.3] transition-opacity group-hover:opacity-70 sm:text-xl"
        style="font-family: 'Instrument Serif', serif;"
      >
        {title}
      </h3>
      <p class="text-sm leading-relaxed text-black/60">{abstract}</p>
    </a>
  </div>
  {
    cover && (
      <div class="relative h-20 w-20 overflow-hidden rounded-md mt-2 sm:mt-0">
        <img
          src={cover}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      </div>
    )
  }
</div>
