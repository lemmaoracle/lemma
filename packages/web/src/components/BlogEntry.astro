---
interface Props {
  slug: string;
  date: string;
  category: string;
  title: string;
  abstract: string;
  categoryColor?: string;
}

const { slug, date, category, title, abstract, categoryColor = "#000" } = Astro.props;
const base = import.meta.env.BASE_URL;
const href = `${base}blog/${slug}`;
const bgColor = `${categoryColor}15`;
---

<div
  class="group grid cursor-pointer grid-cols-[100px_120px_1fr] gap-6 border-b border-black/5 py-5 transition-colors hover:bg-black/[0.02]"
>
  <div class="pt-1 font-mono text-[11px] tracking-wide text-black/40">{date}</div>
  <div class="pt-1">
    <span
      class="rounded-sm px-2 py-1 font-mono text-[10px] tracking-wider uppercase"
      style={`background-color: ${bgColor}; color: ${categoryColor};`}
    >
      {category}
    </span>
  </div>
  <div class="min-w-0">
    <a href={href} class="block">
      <h3
        class="mb-2 text-[20px] leading-[1.3] transition-opacity group-hover:opacity-70"
        style="font-family: 'Instrument Serif', serif;"
      >
        {title}
      </h3>
      <p class="text-[13px] leading-relaxed text-black/60">{abstract}</p>
    </a>
  </div>
</div>
