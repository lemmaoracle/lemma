---
import type { Locale } from "../i18n/translations";
import { getTranslations } from "../i18n/translations";

export interface CtaSectionProps {
  tag?: string;
  h2?: string;
  h2Em?: string;
  p?: string;
  ctaText?: string;
  ctaLink?: string;
  wpText?: string;
  wpLink?: string;
  bgImageSrc?: string;
  locale?: Locale;
  base?: string;
}

const {
  locale = "en",
  tag,
  h2,
  h2Em,
  p,
  ctaText,
  base = "",
  ctaLink = `${base}/services/`,
  wpText,
  wpLink = locale === "ja" ? "https://tally.so/r/xX0VYv" : "https://tally.so/r/7RJXdR",
  bgImageSrc,
} = Astro.props as CtaSectionProps;

const t = getTranslations(locale);

const finalTag = tag ?? t.ctaSection.finalTag;
const finalH2 = h2 ?? t.ctaSection.finalH2;
const finalH2Em = h2Em ?? t.ctaSection.finalH2Em;
const finalP = p ?? t.ctaSection.finalP;
const finalCtaText = ctaText ?? t.ctaSection.finalCtaText;
const finalWpText = wpText ?? t.ctaSection.finalWpText;
---

<section class="cta-section reveal">
  {
    bgImageSrc ? (
      <>
        <div class="cta-bg" style={`background-image: url(${bgImageSrc})`} />
        <div class="cta-overlay" />
      </>
    ) : null
  }
  <div class="cta-inner">
    <div class="cta-eyebrow">{finalTag}</div>
    <h2>
      <span set:html={finalH2}></span>
      <br />
      <em>{finalH2Em}</em>
    </h2>
    <div class="cta-rule"></div>
    <p set:html={finalP}></p>
    <div class="cta-btns">
      <a href={ctaLink} class="btn-cta">{finalCtaText}</a>
      <a href={wpLink} class="btn-cta-outline" target="_blank">{finalWpText}</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
    background: #000;
    padding: 160px 10%;
    text-align: center;
    overflow: hidden;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    background: center/cover no-repeat;
    filter: saturate(0.35) brightness(0.55);
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.76);
  }
  .cta-inner {
    position: relative;
    z-index: 2;
  }
  .cta-eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #8b4513;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .cta-section h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.5vw, 66px);
    font-weight: 300;
    line-height: 1.08;
    color: #fff;
    margin-bottom: 8px;
  }
  .cta-section h2 em {
    font-style: italic;
  }
  .cta-rule {
    width: 40px;
    height: 1px;
    background: #8b4513;
    margin: 32px auto;
  }
  .cta-section p {
    font-size: 14px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.4);
    max-width: 380px;
    margin: 0 auto 48px;
  }
  .cta-btns {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .btn-cta {
    background: #fff;
    color: #000;
    padding: 16px 44px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    display: inline-block;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .btn-cta:hover {
    background: #8b4513;
    color: #fff;
  }
  .btn-cta-outline {
    background: transparent;
    color: rgba(255, 255, 255, 0.65);
    padding: 15px 44px;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border: 1px solid rgba(255, 255, 255, 0.28);
    cursor: pointer;
    display: inline-block;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .btn-cta-outline:hover {
    border-color: rgba(255, 255, 255, 0.6);
    color: #fff;
  }
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.8s ease,
      transform 0.8s ease;
  }
  .reveal.on {
    opacity: 1;
    transform: translateY(0);
  }
  @media (max-width: 768px) {
    .cta-section {
      padding: 100px 6%;
    }
    .cta-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .cta-btns {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
