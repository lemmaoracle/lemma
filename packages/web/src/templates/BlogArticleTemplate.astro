---
import type { Locale, Translations } from "../i18n/translations";
import type { BlogPost } from "../data/blog";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import HubSpotDrawer from "../components/HubSpotDrawer.astro";
import SchemaOrg from "@/components/SchemaOrg";
import defaultCover from "../assets/default-blog-cover.png";

export interface BlogArticleTemplateProps {
  locale: Locale;
  t: Translations;
  base: string;
  blogPath: string;
  post: BlogPost;
  navigation: {
    prev?: { slug: string; title: string; date: string; category: string };
    next?: { slug: string; title: string; date: string; category: string };
  };
  related: Array<{
    cover?: string;
    category: string;
    date: string;
    title: string;
    slug: string;
  }>;
  partnerCtaTitle: string;
  partnerCtaDesc: string;
  partnerCtaButton: string;
  relatedLabel: string;
}

const { locale, t, base, blogPath, post, navigation, related, partnerCtaTitle, partnerCtaDesc, partnerCtaButton, relatedLabel } = Astro.props as BlogArticleTemplateProps;
---

<Layout
  locale={locale}
  title={`${post.title} — Lemma Oracle`}
  description={post.abstract}
  metaType="article"
  post={post}
  blogPath={blogPath}
>
  {post && <SchemaOrg post={post} base={base} blogPath={blogPath} />}
  <Navigation locale={locale} t={t.nav} base={base} />
  <HubSpotDrawer />

  <section class="article-hero">
    <img src={post.cover ?? defaultCover.src} alt="" />
    <div class="article-hero-overlay"></div>
    <div class="article-hero-meta">
      <div class="eyebrow">{post.category} <span class="eyebrow-date">{post.date}</span></div>
      <h1 class="article-hero-title">{post.title}</h1>
    </div>
  </section>

  <div class="prose-wrap">
    <div class="breadcrumb">
      <a href={blogPath}>Blog</a>
      <span class="breadcrumb-sep">/</span>
      <a href={blogPath}>{post.category}</a>
      <span class="breadcrumb-sep">/</span>
      <span>{post.title}</span>
    </div>

    <div class="article-body" set:html={post.body} />

    <div class="article-cta">
      <div class="article-cta-eyebrow">{partnerCtaTitle}</div>
      <h2>Built for decisions<br><em>that matter.</em></h2>
      <div class="article-cta-rule"></div>
      <p>{partnerCtaDesc}</p>
      <a href={`${base}/services`} class="btn-cta-main">{partnerCtaButton}</a>
    </div>
  </div>

  <div class="prevnext">
    {navigation.prev && (
      <a href={`${blogPath}/${navigation.prev.slug}`} class="prevnext-item">
        <div class="prevnext-dir">← Previous</div>
        <div class="prevnext-title">{navigation.prev.title}</div>
        <div class="prevnext-date">{navigation.prev.date} · {navigation.prev.category}</div>
      </a>
    )}
    {navigation.next && (
      <a href={`${blogPath}/${navigation.next.slug}`} class="prevnext-item">
        <div class="prevnext-dir right">Next →</div>
        <div class="prevnext-title right">{navigation.next.title}</div>
        <div class="prevnext-date right">{navigation.next.date} · {navigation.next.category}</div>
      </a>
    )}
  </div>

  {related.length > 0 && (
    <div class="related-section">
      <div class="related-label">{relatedLabel}</div>
      <div class="related-list">
        {related.map((r) => (
          <a href={`${blogPath}/${r.slug}`} class="related-item">
            <div class="related-thumb" style={`background-image:url('${r.cover ?? ""}')`}></div>
            <div class="related-body">
              <div class="related-cat">{r.category} · {r.date}</div>
              <div class="related-title">{r.title}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <Footer locale={locale} t={t.nav} footerT={t.footer} base={base} />
</Layout>

<style>
  .article-hero { margin-top: 64px; position: relative; height: 56vh; min-height: 400px; overflow: hidden; }
  .article-hero img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.5) brightness(.8); }
  .article-hero-overlay { position: absolute; inset: 0; background: linear-gradient(180deg,rgba(0,0,0,.1) 0%,rgba(0,0,0,.72) 100%); }
  .article-hero-meta { position: absolute; bottom: 0; left: 0; right: 0; padding: 0 max(5%, calc(50% - 420px)) 52px; }
  .eyebrow { font-size: 10px; font-weight: 500; letter-spacing: .24em; text-transform: uppercase; color: #8B4513; margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
  .eyebrow::before { content: ''; width: 20px; height: 1px; background: #8B4513; display: block; }
  .eyebrow-date { font-size: 11px; color: rgba(255,255,255,.4); margin-left: 12px; }
  .article-hero-title { font-family: var(--font-display); font-size: clamp(30px,4.5vw,54px); font-weight: 300; color: #fff; line-height: 1.1; max-width: 720px; }

  .prose-wrap { max-width: 680px; margin: 0 auto; padding: 64px 24px 0; }

  .breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 52px; font-size: 11px; color: var(--gray-500); flex-wrap: wrap; }
  .breadcrumb a { color: var(--gray-500); transition: color .2s; text-decoration: none; }
  .breadcrumb a:hover { color: #000; }
  .breadcrumb-sep { color: var(--gray-200); }

  .article-body :global(h2) { font-family: var(--font-display); font-size: clamp(24px,3vw,34px); font-weight: 400; color: #000; line-height: 1.2; margin: 72px 0 24px; }
  .article-body :global(h2:first-child) { margin-top: 0; }
  .article-body :global(h3) { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: #000; margin: 40px 0 16px; line-height: 1.3; }
  .article-body :global(p) { font-family: var(--font-display); font-size: 19px; font-weight: 300; line-height: 2.0; color: var(--gray-800); margin-bottom: 28px; letter-spacing: .01em; }
  .article-body :global(ul) { list-style: none; margin: 0 0 32px; padding: 0; }
  .article-body :global(ul li) { font-family: var(--font-display); font-size: 19px; font-weight: 300; line-height: 1.9; color: var(--gray-800); padding: 6px 0 6px 24px; position: relative; }
  .article-body :global(ul li::before) { content: '◆'; position: absolute; left: 0; color: var(--accent); font-size: 8px; top: 13px; }
  .article-body :global(strong) { font-weight: 600; }
  .article-body :global(hr) { border: none; border-top: 1px solid var(--gray-200); margin: 56px 0; }
  .article-body :global(table) { width: 100%; min-width: 560px; border-collapse: collapse; font-size: 15px; margin: 40px 0; }
  .article-body :global(thead tr) { background: #000; color: #fff; }
  .article-body :global(th) { padding: 14px 18px; font-size: 10px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; text-align: left; white-space: nowrap; }
  .article-body :global(td) { padding: 14px 18px; border-bottom: 1px solid var(--gray-200); color: var(--gray-800); line-height: 1.65; vertical-align: top; }
  .article-body :global(tr:nth-child(odd) td) { background: var(--gray-50); }
  .article-body :global(pre) { margin: 32px 0; padding: 24px; background: #1a1a1a; border-radius: 4px; overflow-x: auto; }
  .article-body :global(pre code) { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 14px; line-height: 1.7; color: #e1e4e8; }

  .article-cta { margin: 80px -24px 0; background: #000; padding: 64px 48px; text-align: center; border-top: 3px solid #8B4513; }
  .article-cta-eyebrow { font-size: 10px; font-weight: 500; letter-spacing: .28em; text-transform: uppercase; color: #8B4513; margin-bottom: 20px; }
  .article-cta h2 { font-family: var(--font-display); font-size: clamp(28px,4vw,44px); font-weight: 300; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .article-cta h2 em { font-style: italic; }
  .article-cta-rule { width: 40px; height: 1px; background: #8B4513; margin: 24px auto; }
  .article-cta p { font-size: 15px; color: rgba(255,255,255,.45); line-height: 1.75; max-width: 400px; margin: 0 auto 40px; }
  .btn-cta-main {
    background: #fff; color: #000; padding: 18px 52px; font-size: 12px; font-weight: 500;
    letter-spacing: .16em; text-transform: uppercase; border: none; cursor: pointer; display: inline-block;
    transition: background .2s, color .2s;
  }
  .btn-cta-main:hover { background: #8B4513; color: #fff; }

  .prevnext { max-width: 680px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: var(--gray-200); margin-top: 2px; }
  .prevnext-item { background: #fff; padding: 28px 32px; border-top: 2px solid transparent; transition: border-color .2s; display: flex; flex-direction: column; gap: 6px; text-decoration: none; color: inherit; }
  .prevnext-item:hover { border-top-color: #8B4513; }
  .prevnext-dir { font-size: 10px; font-weight: 500; letter-spacing: .14em; text-transform: uppercase; color: #8B4513; }
  .prevnext-dir.right { text-align: right; }
  .prevnext-title { font-family: var(--font-display); font-size: 16px; font-weight: 400; color: #000; line-height: 1.35; }
  .prevnext-title.right { text-align: right; }
  .prevnext-date { font-size: 11px; color: var(--gray-500); }
  .prevnext-date.right { text-align: right; }

  .related-section { max-width: 680px; margin: 72px auto 0; padding: 0 24px; }
  .related-label { font-size: 10px; font-weight: 500; letter-spacing: .22em; text-transform: uppercase; color: #8B4513; margin-bottom: 28px; display: flex; align-items: center; gap: 10px; }
  .related-label::before { content: ''; width: 18px; height: 1px; background: #8B4513; display: block; }
  .related-list { display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--gray-200); }
  .related-item { display: flex; align-items: flex-start; gap: 20px; padding: 24px 0; border-bottom: 1px solid var(--gray-200); transition: opacity .2s; text-decoration: none; color: inherit; }
  .related-item:hover { opacity: .75; }
  .related-thumb { width: 100px; height: 64px; flex-shrink: 0; background-size: cover; background-position: center; filter: saturate(.4) brightness(.88); }
  .related-body { flex: 1; display: flex; flex-direction: column; gap: 5px; }
  .related-cat { font-size: 10px; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: #8B4513; }
  .related-title { font-family: var(--font-display); font-size: 17px; font-weight: 400; color: #000; line-height: 1.3; }

  @media(max-width:768px) {
    .prose-wrap { padding: 48px 20px 0; }
    .article-cta { margin: 64px -20px 0; padding: 48px 28px; }
    .prevnext { margin-left: 0; margin-right: 0; grid-template-columns: 1fr; }
    .related-section { padding: 0 20px; }
  }
</style>
