---
import type { Locale } from "../i18n/translations";
import type { BlogPost } from "../data/blog";
import { getTranslations } from "../i18n/translations";
import MetaTags from "@/components/MetaTags";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
  metaType?: "home" | "article";
  post?: BlogPost;
  blogPath?: string;
  bodyClass?: string;
  noindex?: boolean;
}

const { locale = "en", bodyClass, noindex } = Astro.props;
const t = getTranslations(locale);
const title = Astro.props.title ?? t.layout.defaultTitle;
const description = Astro.props.description ?? t.layout.defaultDescription;
const base = locale === "ja" ? "/ja" : "";

const shouldRenderMetaTags =
  Astro.props.metaType === "home" || (Astro.props.metaType === "article" && Astro.props.post);

const googleAnalyticsId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;
---

<!doctype html>
<html lang={locale}>
  <head prefix="og: https://ogp.me/ns#">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={base ? `${base}/favicon.svg` : "/favicon.svg"} />
    <meta property="og:site_name" content="Lemma Oracle" />
    <meta name="twitter:card" content="summary_large_image" />
    {
      shouldRenderMetaTags && Astro.props.metaType === "home" && (
        <MetaTags type="home" title={title} description={description} base={base} locale={locale} />
      )
    }
    {
      shouldRenderMetaTags &&
        Astro.props.metaType === "article" &&
        Astro.props.post &&
        Astro.props.blogPath && (
          <MetaTags
            type="article"
            post={Astro.props.post}
            base={base}
            blogPath={Astro.props.blogPath}
            locale={locale}
          />
        )
    }
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,300;1,9..40,400;1,9..40,500;1,9..40,600;1,9..40,700&family=Noto+Serif+JP:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Lemma Oracle Blog (English)"
      href={new URL("rss.xml", Astro.site)}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Lemma Oracle ブログ (日本語)"
      href={new URL("ja/rss.xml", Astro.site)}
    />
    {
      googleAnalyticsId && (
        <>
          <script
            is:inline
            src={`https://www.googletagmanager.com/gtag/js?id=${googleAnalyticsId}`}
          />
          <script
            is:inline
            set:html={`
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', '${googleAnalyticsId}');
            `}
          />
        </>
      )
    }
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  :root {
    --black: #000000;
    --white: #FFFFFF;
    --gray-50: #F5F5F5;
    --gray-200: #E0E0E0;
    --gray-500: #9E9E9E;
    --gray-800: #1A1A1A;
    --accent: #8B4513;
    --accent-bg: #F5EFE6;
    --font-display: 'Cormorant Garamond', 'Noto Serif JP', Georgia, serif;
    --font-body: 'DM Sans', 'Hiragino Sans', 'Yu Gothic', sans-serif;
  }

  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    background: var(--white);
    color: var(--black);
    overflow-x: hidden;
  }
</style>
