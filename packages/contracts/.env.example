# Environment Variables for LemmaOracle Contracts Deployment

# Private key for deployment (without 0x prefix)
PRIVATE_KEY=

# RPC URLs
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID
MAINNET_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
# Monad RPC URLs (optional - defaults to public endpoints)
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC_URL=https://rpc.monad.xyz

# Etherscan API Key for contract verification (works for Ethereum and Monad networks)
ETHERSCAN_API_KEY=

# Gas Configuration (optional)
# GAS_PRICE=
# GAS_LIMIT=