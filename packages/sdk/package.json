{
  "name": "@lemmaoracle/sdk",
  "version": "0.0.20",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemmaoracle/lemma.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/lemmaoracle/lemma/tree/main/packages/sdk#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./schemas": {
      "types": "./dist/namespaces/schemas.d.ts",
      "import": "./dist/namespaces/schemas.js",
      "default": "./dist/namespaces/schemas.js"
    },
    "./circuits": {
      "types": "./dist/namespaces/circuits.d.ts",
      "import": "./dist/namespaces/circuits.js",
      "default": "./dist/namespaces/circuits.js"
    },
    "./generators": {
      "types": "./dist/namespaces/generators.d.ts",
      "import": "./dist/namespaces/generators.js",
      "default": "./dist/namespaces/generators.js"
    },
    "./attributes": {
      "types": "./dist/namespaces/attributes.d.ts",
      "import": "./dist/namespaces/attributes.js",
      "default": "./dist/namespaces/attributes.js"
    },
    "./documents": {
      "types": "./dist/namespaces/documents.d.ts",
      "import": "./dist/namespaces/documents.js",
      "default": "./dist/namespaces/documents.js"
    },
    "./proofs": {
      "types": "./dist/namespaces/proofs.d.ts",
      "import": "./dist/namespaces/proofs.js",
      "default": "./dist/namespaces/proofs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run"
  },
  "dependencies": {
    "@docknetwork/crypto-wasm": "^0.35.0",
    "@lemmaoracle/spec": "workspace:*",
    "poseidon-lite": "^0.2.0",
    "ramda": "^0.30.1",
    "snarkjs": "^0.7.5",
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0",
    "@noble/ciphers": "^1.2.0"
  },
  "devDependencies": {
    "@types/ramda": "^0.30.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-functional": "^9.0.4",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
