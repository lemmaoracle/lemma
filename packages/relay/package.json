{
  "name": "@lemmaoracle/relay",
  "version": "0.1.0",
  "private": true,
  "description": "Node.js relay for Lemma SDK functions that cannot run on edge runtimes",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@lemmaoracle/sdk": "workspace:*",
    "ramda": "^0.30.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/ramda": "^0.31.1",
    "eslint": "^9.17.0",
    "eslint-plugin-functional": "^6.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "eslintConfig": {
    "extends": [
      "../../.eslintrc.json"
    ]
  }
}
