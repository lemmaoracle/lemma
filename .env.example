# Lemma x x402 Integration Environment Variables
# Copy this file to .env and fill in your values

# Ethereum/Monad Configuration
PRIVATE_KEY=your_private_key_here
RPC_URL=https://testnet-rpc.monad.xyz
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Pinata (IPFS)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_api_key_here

# Lemma API
LEMMA_API_KEY=your_lemma_api_key_here

# Circuit IDs
X402_CIRCUIT_ID=x402-payment-v1.2
EXAMPLE_CIRCUIT_ID=example-circuit-v1.2

# Verifier Addresses (example - use actual deployed addresses)
X402_VERIFIER=0x0000000000000000000000000000000000000000
EXAMPLE_VERIFIER=0x0000000000000000000000000000000000000000

# Note: For actual deployment, use:
# X402_VERIFIER=0x02eC0F2b3C42E5696C0F8DAaE78b76ed28A4eE62
# EXAMPLE_VERIFIER=0x354cc716ffc02F57Ff7B0bDd465E9C7f12b785E9